# ShipSmart-MCP — environment variables
# Copy to .env and fill in real values for local development.
# Production values are set in the Render dashboard (never commit real secrets).

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO

# CORS — who is allowed to call the MCP server
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,http://localhost:8080

# Optional API key clients must pass in the `X-MCP-Api-Key` header.
# Leave empty to disable auth (OK for local dev, not for production).
MCP_API_KEY=

# ── Shipping Provider ────────────────────────────────────────────────────────
# One of: mock, ups, fedex, dhl, usps
SHIPPING_PROVIDER=mock

UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_BASE_URL=https://onlinetools.ups.com

FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_BASE_URL=https://apis.fedex.com

DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_BASE_URL=https://express.api.dhl.com

USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
USPS_BASE_URL=https://api.usps.com
